rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── WHITELIST: Solo Mateo y Mónica ──
    function isWhitelisted() {
      return request.auth != null && (
        request.auth.token.email == "mateo.ou@gmail.com" ||
        request.auth.token.email == "1976Monicagc@dompavolei.com"
      );
    }

    function isMember(familyId) {
      return exists(
        /databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid)
      );
    }

    // ── Families ──
    match /families/{familyId} {
      allow create: if isWhitelisted();
      allow read: if isWhitelisted() && isMember(familyId);
    }

    // ── Members ──
    match /families/{familyId}/members/{memberId} {
      allow create: if isWhitelisted();
      allow read: if isWhitelisted() && isMember(familyId);
      allow update, delete: if isWhitelisted() && memberId == request.auth.uid;
    }

    // ── Activities ──
    match /families/{familyId}/activities/{activityId} {
      allow read: if isWhitelisted() && isMember(familyId);
      allow create: if isWhitelisted();
      allow delete: if isWhitelisted() && request.auth.uid == resource.data.uid;
    }

    // ── Wellness ──
    match /families/{familyId}/wellness/{docId} {
      allow read, create: if isWhitelisted();
      allow delete: if isWhitelisted() && request.auth.uid == resource.data.uid;
    }
  }
}
