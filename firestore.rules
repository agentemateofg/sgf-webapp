rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: authed and matches uid
    function isUser() {
      return request.auth != null;
    }

    // Families: anyone can create, read if member
    match /families/{familyId} {
      allow create: if isUser();
      allow read: if isUser() && exists(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid));
    }

    // Members: anyone can add to a family, read all if member
    match /families/{familyId}/members/{memberId} {
      allow create: if isUser();
      allow read: if isUser() && exists(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid));
      allow update, delete: if isUser() && request.auth.uid == memberId;
    }

    // Activities: read if member, write only own docs
    match /families/{familyId}/activities/{activityId} {
      allow read: if isUser() && exists(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid));
      allow create: if isUser() && request.auth.uid == request.resource.data.uid;
      allow delete: if isUser() && request.auth.uid == resource.data.uid;
    }

    // Wellness (legacy metrics): same as activities
    match /families/{familyId}/wellness/{docId} {
      allow read, create: if isUser() && exists(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid));
      allow delete: if isUser() && request.auth.uid == resource.data.uid;
    }
  }
}
